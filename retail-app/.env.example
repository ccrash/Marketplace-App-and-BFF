# Physical device with QR code(iOS or Android): use your machine's LAN IP
# Find it with `ipconfig` (Windows) or `ifconfig` (Mac/Linux)
EXPO_PUBLIC_BFF_URL=http://192.168.x.x:3000

# iOS Simulator: localhost works fine
# EXPO_PUBLIC_BFF_URL=http://localhost:3000

# Android Emulator: use the special alias for the host machine
# EXPO_PUBLIC_BFF_URL=http://10.0.2.2:3000

